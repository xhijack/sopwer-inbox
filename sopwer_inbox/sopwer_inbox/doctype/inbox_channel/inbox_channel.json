  {
   "fieldname": "meta_section",
   "fieldtype": "Section Break",
   "label": "Meta",
   "depends_on": "eval:doc.channel_type==\"Facebook Messenger\"||doc.channel_type==\"Instagram\"||doc.channel_type==\"WhatsApp Cloud\""
  },
  {
   "description": "Facebook Page ID. Used to SEND messages and SUBSCRIBE the webhook — for both Messenger and Instagram (Instagram DMs are sent via the linked Page).",
   "fieldname": "meta_page_id",
   "fieldtype": "Data",
   "label": "Facebook Page ID"
  },
  {
   "depends_on": "eval:doc.channel_type==\"Instagram\"",
   "description": "Instagram account id (instagram_business_account.id). Instagram only — used to ROUTE inbound webhooks (entry.id). Get via GET /{page-id}?fields=instagram_business_account.",
   "fieldname": "meta_ig_account_id",
   "fieldtype": "Data",
   "label": "IG Account ID"
  },
  {
   "depends_on": "eval:doc.channel_type==\"WhatsApp Cloud\"",
   "description": "Cloud API Phone Number ID. Used as the send target and inbound routing key (value.metadata.phone_number_id).",
   "fieldname": "meta_phone_number_id",
   "fieldtype": "Data",
   "label": "WA Phone Number ID"
  },
  {
   "depends_on": "eval:doc.channel_type==\"WhatsApp Cloud\"",
   "description": "WhatsApp Business Account ID. Used to subscribe the WABA to this app.",
   "fieldname": "meta_waba_id",
   "fieldtype": "Data",
   "label": "WhatsApp Business Account ID"
  },
  {
   "description": "Meta App ID (App Dashboard → Settings → Basic). Needed for the one-click webhook registration.",
   "fieldname": "meta_app_id",
   "fieldtype": "Data",
   "label": "App ID"
  },
  {
   "description": "Long-lived Page Access Token. Encrypted at rest.",
   "fieldname": "meta_page_access_token",
   "fieldtype": "Password",
   "label": "Page Access Token",
   "length": 500
  },
  {
   "description": "App Secret for X-Hub-Signature-256 verification. Encrypted at rest.",
   "fieldname": "meta_app_secret",
   "fieldtype": "Password",
   "label": "App Secret"
  },
  {
   "description": "Shared secret for GET subscription verification (hub.verify_token).",
   "fieldname": "meta_verify_token",
   "fieldtype": "Data",
   "label": "Verify Token"
  },
  {
   "default": "v21.0",
   "description": "Graph API version, e.g. v21.0.",
   "fieldname": "meta_api_version",
   "fieldtype": "Data",
   "label": "API Version"
  },
  {
   "fieldname": "routing_section",
   "fieldtype": "Section Break",
   "label": "Routing"
  },
  {
   "description": "Shared secret used to verify inbound webhooks.",
   "fieldname": "webhook_secret",
   "fieldtype": "Password",
   "label": "Webhook Secret"
  },
  {
   "description": "Batasi dokumen ERP yang tampil & bisa dikirim ke company ini. Kosongkan untuk tanpa batasan.",
   "fieldname": "company",
   "fieldtype": "Link",
   "label": "Company (ERPNext)",
   "options": "Company",
   "reqd": 0
  }
